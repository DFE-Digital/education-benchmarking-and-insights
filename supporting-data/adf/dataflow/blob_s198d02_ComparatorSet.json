{
	"name": "blob_s198d02_ComparatorSet",
	"properties": {
		"folder": {
			"name": "blob_s198d02"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "blob_comparatorSet",
						"type": "DatasetReference"
					},
					"name": "source"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "s198d02_ComparatorSet",
						"type": "DatasetReference"
					},
					"name": "sink"
				}
			],
			"transformations": [
				{
					"name": "AlterRow"
				}
			],
			"scriptLines": [
				"source(output(",
				"          RunType as string,",
				"          RunId as string,",
				"          URN as string,",
				"          SetType as string,",
				"          Pupil as string,",
				"          Building as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source",
				"source alterRow(upsertIf(true())) ~> AlterRow",
				"AlterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          RunType as string,",
				"          RunId as string,",
				"          URN as string,",
				"          SetType as string,",
				"          Pupil as string,",
				"          Building as string",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['URN'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink"
			]
		}
	}
}