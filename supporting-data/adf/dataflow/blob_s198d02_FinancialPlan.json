{
	"name": "blob_s198d02_FinancialPlan",
	"properties": {
		"folder": {
			"name": "blob_s198d02"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "blob_FinancialPlan",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "AlterRow1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          URN as string,",
				"          Year as string,",
				"          Input as string,",
				"          DeploymentPlan as string,",
				"          Created as string,",
				"          CreatedBy as string,",
				"          UpdatedAt as string,",
				"          UpdatedBy as string,",
				"          IsComplete as string,",
				"          Version as string,",
				"          TeacherContactRatio as string,",
				"          ContactRatioRating as string,",
				"          InYearBalance as string,",
				"          InYearBalancePercentIncomeRating as string,",
				"          AverageClassSize as string,",
				"          AverageClassSizeRating as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"derivedColumn1 alterRow(upsertIf(true())) ~> AlterRow1",
				"source1 derive(Created = toDate(Created),",
				"          UpdatedAt = toDate(UpdatedAt),",
				"          IsComplete = toBoolean(IsComplete),",
				"          Version = toInteger(Version),",
				"          TeacherContactRatio = toDecimal(TeacherContactRatio),",
				"          InYearBalance = toDecimal(InYearBalance),",
				"          AverageClassSize = toDecimal(AverageClassSize)) ~> derivedColumn1",
				"AlterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table') ~> sink1"
			]
		}
	}
}