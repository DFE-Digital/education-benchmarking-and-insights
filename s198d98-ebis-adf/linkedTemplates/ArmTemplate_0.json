{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "s198d98-ebis-adf"
		},
		"s198d01_keyvault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://s198d01-ebis-keyvault.vault.azure.net/"
		},
		"s198p02_keyvault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://s198p02-ebis-keyvault.vault.azure.net/"
		},
		"s198t01_keyvault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://s198t01-ebis-keyvault.vault.azure.net/"
		},
		"s198d01_cosmos_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "supporting-data-cosmos-connection-string"
		},
		"s198d01_sql_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "ebis-sql-connection-string"
		},
		"s198d98_storage_sasUri": {
			"type": "secureString",
			"metadata": "Secure string for 'sasUri' of 's198d98_storage'"
		},
		"s198d98_storage_properties_typeProperties_sasToken_secretName": {
			"type": "string",
			"defaultValue": "supporting-data-storage-sas-token"
		},
		"s198p02_cosmos_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "adf-cosmos-connection-string"
		},
		"s198p02_sql_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "ebis-sql-connection-string"
		},
		"s198t01_cosmos_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "adf-cosmos-connection-string"
		},
		"s198t01_sql_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "ebis-sql-connection-string"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/s198d01_keyvault')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureKeyVault",
				"typeProperties": {
					"baseUrl": "[parameters('s198d01_keyvault_properties_typeProperties_baseUrl')]"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198p02_keyvault')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureKeyVault",
				"typeProperties": {
					"baseUrl": "[parameters('s198p02_keyvault_properties_typeProperties_baseUrl')]"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198t01_keyvault')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureKeyVault",
				"typeProperties": {
					"baseUrl": "[parameters('s198t01_keyvault_properties_typeProperties_baseUrl')]"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198d01_cosmos')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "CosmosDb",
				"typeProperties": {
					"connectionString": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "s198d01_keyvault",
							"type": "LinkedServiceReference"
						},
						"secretName": "[parameters('s198d01_cosmos_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/s198d01_keyvault')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198d01_sql')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"connectionString": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "s198d01_keyvault",
							"type": "LinkedServiceReference"
						},
						"secretName": "[parameters('s198d01_sql_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/s198d01_keyvault')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198d98_storage')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobStorage",
				"typeProperties": {
					"sasUri": "[parameters('s198d98_storage_sasUri')]",
					"sasToken": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "s198d01_keyvault",
							"type": "LinkedServiceReference"
						},
						"secretName": "[parameters('s198d98_storage_properties_typeProperties_sasToken_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/s198d01_keyvault')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198p02_cosmos')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "CosmosDb",
				"typeProperties": {
					"connectionString": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "s198p02_keyvault",
							"type": "LinkedServiceReference"
						},
						"secretName": "[parameters('s198p02_cosmos_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/s198p02_keyvault')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198p02_sql')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"connectionString": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "s198p02_keyvault",
							"type": "LinkedServiceReference"
						},
						"secretName": "[parameters('s198p02_sql_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/s198p02_keyvault')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198t01_cosmos')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "CosmosDb",
				"typeProperties": {
					"connectionString": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "s198t01_keyvault",
							"type": "LinkedServiceReference"
						},
						"secretName": "[parameters('s198t01_cosmos_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/s198t01_keyvault')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/s198t01_sql')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"connectionString": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "s198t01_keyvault",
							"type": "LinkedServiceReference"
						},
						"secretName": "[parameters('s198t01_sql_properties_typeProperties_connectionString_secretName')]"
					}
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/s198t01_keyvault')]"
			]
		}
	]
}