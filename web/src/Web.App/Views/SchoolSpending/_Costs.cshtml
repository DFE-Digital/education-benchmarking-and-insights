@model Web.App.ViewModels.CostsViewModel

@if (Model.Costs.Any())
{
    var costs = Model.Costs.ToList();

    @for (var i = 0; i < costs.Count; i++)
    {
        var category = costs.ElementAtOrDefault(i);
        @await Component.InvokeAsync("PriorityCostCategory", new
        {
            id = Model.Id,
            urn = Model.Urn,
            isPartOfTrust = Model.IsPartOfTrust,
            isCustomData = Model.IsCustomData,
            hasIncompleteData = Model.HasIncompleteData,
            costCategory = category,
            isFirstItem = i == 0
        })
    }
}